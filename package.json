{
	"name": "tanstack-start-convex-saas-template",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 3000",
		"build": "vite build",
		"preview": "vite preview",
		"deploy": "bun run deploy:prod",
		"deploy:cloudflare": "vite build && wrangler deploy --config dist/server/wrangler.json",
		"deploy:prod": "convex deploy --env-file .env.production --cmd 'bun --no-env-file run deploy:cloudflare' --cmd-url-env-var-name VITE_CONVEX_URL",
		"dev:cloudflare": "wrangler dev",
		"typecheck": "tsc --noEmit",
		"check": "biome check .",
		"lint": "biome lint .",
		"format": "biome format . --write",
		"convex:dev": "convex dev",
		"convex:codegen": "convex codegen"
	},
	"dependencies": {
		"@auth/core": "0.37.0",
		"@convex-dev/auth": "^0.0.92",
		"@dodopayments/tanstack": "^0.2.7",
		"@fontsource-variable/geist": "^5.2.8",
		"@radix-ui/react-slot": "^1.2.4",
		"@tailwindcss/vite": "^4.2.4",
		"@tanstack/react-devtools": "^0.9.9",
		"@tanstack/react-router": "1.166.2",
		"@tanstack/react-router-devtools": "1.166.2",
		"@tanstack/react-start": "1.166.2",
		"@tanstack/router-plugin": "1.166.2",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"convex": "^1.36.0",
		"dodopayments": "^2.31.0",
		"lucide-react": "^1.14.0",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.2.4",
		"tw-animate-css": "^1.4.0",
		"zod": "^4.1.13"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@cloudflare/vite-plugin": "^1.36.4",
		"@tanstack/devtools-vite": "^0.7.0",
		"@types/node": "^25.3.3",
		"@types/react": "^19.2.0",
		"@types/react-dom": "^19.2.0",
		"@vitejs/plugin-react": "^5.0.4",
		"typescript": "^5.7.2",
		"vite": "^8.0.10",
		"wrangler": "^4.90.1"
	},
	"packageManager": "bun@1.2.23"
}
